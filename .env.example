EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional alias if Supabase dashboard labels the public key as publishable.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional override. Defaults to ${EXPO_PUBLIC_SUPABASE_URL}/functions/v1.
EXPO_PUBLIC_SUPABASE_FUNCTIONS_URL=
EXPO_PUBLIC_SUPPORT_EMAIL=one22gym@gmail.com
EXPO_PUBLIC_FEEDBACK_EMAIL=one22gym@gmail.com
# Optional. Leave false for TestFlight unless debugging a specific build.
EXPO_PUBLIC_ENABLE_DEBUG_LOGS=false
EXPO_PUBLIC_EXERCISEDB_API_KEY=your-exercisedb-key
REVENUECAT_IOS_KEY=your-ios-key
REVENUECAT_ANDROID_KEY=your-android-key

# CoachRevisionProposal dev-active mode (dev builds only — env.ts gates
# 'active' behind __DEV__, production always resolves off). Keep in .env
# rather than inline on `expo start`, otherwise a restart silently drops the
# flags and coach edits fall back to legacy paths.
EXPO_PUBLIC_COACH_REVISION_PROPOSAL_MODE=active
EXPO_PUBLIC_COACH_REVISION_PROPOSAL_DEV_ACTIVE=1

# Server-only Supabase edge-function secrets. Set these with
# `supabase secrets set ...`; never prefix them with EXPO_PUBLIC_.
# OPENAI_API_KEY=your-private-openai-key
# COACH_LLM_PROVIDER=openai
# COACH_LLM_MODEL=gpt-5.5
