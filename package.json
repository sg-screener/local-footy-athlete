    "test:scenarios:golden": "npm run test:compile && node src/__tests__/scenarioHarness.js --golden",
    "test:scenarios:verbose": "npm run test:compile && node src/__tests__/scenarioHarness.js --verbose",
    "test:qa": "tsc --outDir /tmp/lfa-qa --skipLibCheck --esModuleInterop --moduleResolution node --module commonjs --target es2020 --resolveJsonModule --allowJs src/__tests__/weekPlanQA.ts && node /tmp/lfa-qa/__tests__/weekPlanQA.js",
    "test:qa:local": "tsc --outDir .qa-compiled --skipLibCheck --esModuleInterop --moduleResolution node --module commonjs --target es2020 --resolveJsonModule --allowJs src/__tests__/weekPlanQA.ts && node .qa-compiled/__tests__/weekPlanQA.js",
